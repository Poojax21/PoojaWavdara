# ============================================================
# ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!
# ============================================================

# Required: OpenRouter API Key (get free key at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Optional: Your deployed site URL (for OpenRouter referer header)
NEXT_PUBLIC_SITE_URL=https://your-portfolio.vercel.app

# Optional: GitHub Personal Access Token
# Increases API rate limit from 60 to 5000 requests/hour
# Get one at: github.com/settings/tokens (select: public_repo)
GITHUB_TOKEN=

# Optional: Contact form via Formspree (free tier: 50 submissions/month)
# Get your form ID at: formspree.io
# Then update config/portfolio.js → contact.formspreeId
# FORMSPREE_ID=your-form-id
